;`, `&lsquo;`, `&#39;`, `&rsquo;`.","unescapedEntityAlts",["31427","31428","31429","31430"],["31431","31432","31433","31434"],"Replace `tab` with `(tab)`",{"range":"31435","text":"31436"},{"range":"31437","text":"26210"},{"range":"31438","text":"26210"},{"range":"31439","text":"26210"},{"range":"31440","text":"26210"},{"range":"31441","text":"26175"},{"range":"31442","text":"30296"},"Replace `'framer-motion'␍` with `\"framer-motion\";`",{"range":"31443","text":"31444"},"Replace `'gsap'␍` with `\"gsap\";`",{"range":"31445","text":"31446"},"Replace `'@gsap/react'␍` with `\"@gsap/react\";`",{"range":"31447","text":"31448"},{"range":"31449","text":"30416"},{"range":"31450","text":"26210"},{"range":"31451","text":"26175"},{"range":"31452","text":"26210"},{"range":"31453","text":"26210"},{"range":"31454","text":"26175"},{"range":"31455","text":"27150"},"Replace `'Initializing·RAG·Pipeline...')␍` with `\"Initializing·RAG·Pipeline...\");`",{"range":"31456","text":"31457"},{"range":"31458","text":"26175"},{"range":"31459","text":"27150"},{"range":"31460","text":"26210"},{"range":"31461","text":"26175"},{"range":"31462","text":"26175"},{"range":"31463","text":"26175"},{"range":"31464","text":"26175"},{"range":"31465","text":"26210"},{"range":"31466","text":"26175"},{"range":"31467","text":"26210"},"react-hooks/refs","Error: Cannot access refs during render\n\nReact refs are values that are not needed for rendering. Refs should only be accessed outside of render, such as in event handlers or effects. Accessing a ref value (the `current` property) during render can cause your component not to update as expected (https://react.dev/reference/react/useRef).\n\nE:\\Projects\\ui test\\jarvis-unified - Copy\\apps\\desktop\\renderer\\src\\components\\widgets\\deep-research.tsx:23:35\n  21 |   const { contextSafe } = useGSAP({ scope: containerRef })\n  22 |\n> 23 |   const handleStart = contextSafe((e: any) => {\n     |                                   ^^^^^^^^^^^^^\n> 24 |     setQuery(e.detail.query)\n     | ^^^^^^^^^^^^^^^^^^^^^^^^^^^^\n> 25 |     setIsSuccess(null)\n     | ^^^^^^^^^^^^^^^^^^^^^^^^^^^^\n> 26 |     setSummary('')\n     | ^^^^^^^^^^^^^^^^^^^^^^^^^^^^\n> 27 |     setIsOpen(true)\n     | ^^^^^^^^^^^^^^^^^^^^^^^^^^^^\n> 28 |     setStatusText('Booting Deep Search Node...')\n     | ^^^^^^^^^^^^^^^^^^^^^^^^^^^^\n> 29 |     if (progressRef.current) gsap.to(progressRef.current, { width: '5%', duration: 0.5 })\n     | ^^^^^^^^^^^^^^^^^^^^^^^^^^^^\n> 30 |   })\n     | ^^^^ Passing a ref to a function may read its value during render\n  31 |\n  32 |   const handleProgress = contextSafe(\n  33 |     (_event: any, data: { status: string; file: string; totalFound: number }) => {",["31468","31469"],{"range":"31470","text":"26210"},{"range":"31471","text":"26175"},{"range":"31472","text":"26175"},{"range":"31473","text":"27150"},{"range":"31474","text":"26175"},"Replace `'Booting·Deep·Search·Node...')␍` with `\"Booting·Deep·Search·Node...\");`",{"range":"31475","text":"31476"},"Replace `·gsap.to(progressRef.current,·{·width:·'5%',·duration:·0.5·})␍` with `⏎······gsap.to(progressRef.current,·{·width:·\"5%\",·duration:·0.5·});`",{"range":"31477","text":"31478"},{"range":"31479","text":"26175"},{"range":"31480","text":"26210"},{"range":"31481","text":"26210"},"Error: Cannot access refs during render\n\nReact refs are values that are not needed for rendering. Refs should only be accessed outside of render, such as in event handlers or effects. Accessing a ref value (the `current` property) during render can cause your component not to update as expected (https://react.dev/reference/react/useRef).\n\nE:\\Projects\\ui test\\jarvis-unified - Copy\\apps\\desktop\\renderer\\src\\components\\widgets\\deep-research.tsx:33:5\n  31 |\n  32 |   const handleProgress = contextSafe(\n> 33 |     (_event: any, data: { status: string; file: string; totalFound: number }) => {\n     |     ^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^