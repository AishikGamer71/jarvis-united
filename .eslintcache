ange":"39228","text":"26175"},"Replace `·hour12:·false,·hour:·'2-digit',·minute:·'2-digit',·second:·'2-digit'·})` with `⏎············hour12:·false,⏎············hour:·\"2-digit\",⏎············minute:·\"2-digit\",⏎············second:·\"2-digit\",⏎··········});`",{"range":"39229","text":"39230"},"Replace `prev·=>·[...prev.slice(-30),·{·time:·now,·value:·parseFloat(loadRes.cpu)·}])` with `(prev)·=>·[⏎············...prev.slice(-30),⏎············{·time:·now,·value:·parseFloat(loadRes.cpu)·},⏎··········]);`",{"range":"39231","text":"39232"},"Replace `prev·=>·[...prev.slice(-30),·{·time:·now,·value:·parseFloat(loadRes.memory)·}])` with `(prev)·=>·[⏎············...prev.slice(-30),⏎············{·time:·now,·value:·parseFloat(loadRes.memory)·},⏎··········]);`",{"range":"39233","text":"39234"},{"range":"39235","text":"26175"},"Replace `'StartupApps'` with `\"StartupApps\"`",{"range":"39236","text":"39237"},["39238","39239"],"Replace `'get-startup-apps')` with `⏎··········\"get-startup-apps\",⏎········);`",{"range":"39240","text":"39241"},{"range":"39242","text":"26175"},"Replace `'Services'` with `\"Services\"`",{"range":"39243","text":"39244"},["39245","39246"],"Replace `'get-services')` with `⏎··········\"get-services\",⏎········);`",{"range":"39247","text":"39248"},{"range":"39249","text":"26175"},"Replace `'Users'` with `\"Users\"`",{"range":"39250","text":"39251"},["39252","39253"],"Replace `'get-users')` with `⏎··········\"get-users\",⏎········);`",{"range":"39254","text":"39255"},{"range":"39256","text":"26175"},{"range":"39257","text":"26175"},{"range":"39258","text":"26175"},"Error: Calling setState synchronously within an effect can trigger cascading renders\n\nEffects are intended to synchronize state between React and external systems such as manually updating the DOM, state management libraries, or other platform APIs. In general, the body of an effect should do one or both of the following:\n* Update external systems with the latest state from React.\n* Subscribe for updates from some external system, calling setState in a callback function when external state changes.\n\nCalling setState synchronously within an effect body causes cascading renders that can hurt performance, and is not recommended. (https://react.dev/learn/you-might-not-need-an-effect).\n\nE:\\Projects\\ui test\\jarvis-unified - Copy\\apps\\desktop\\renderer\\src\\pages\\task-manager.tsx:168:5\n  166 |\n  167 |   useEffect(() => {\n> 168 |     fetchStats()\n      |     ^^^^^^^^^^ Avoid calling setState() directly within an effect\n  169 |     const interval = setInterval(fetchStats, 2000) \n  170 |     return () => clearInterval(interval)\n  171 |   }, [activeTab])",{"range":"39259","text":"26175"},{"range":"39260","text":"26175"},{"range":"39261","text":"26175"},"React Hook useEffect has a missing dependency: 'fetchStats'. Either include it or remove the dependency array.",["39262"],{"range":"39263","text":"26175"},["39264","39265"],"Replace `'kill-process',·pid)` with `\"kill-process\",·pid);`",{"range":"39266","text":"39267"},{"range":"39268","text":"26175"},{"range":"39269","text":"26175"},"Replace `prev·=>·({·...prev,·[name]:·!prev[name]·}))` with `(prev)·=>·({·...prev,·[name]:·!prev[name]·}));`",{"range":"39270","text":"39271"},{"range":"39272","text":"26175"},["39273","39274"],{"range":"39275","text":"26175"},"Replace `(p` with `((p)`",{"range":"39276","text":"39277"},{"range":"39278","text":"26175"},{"range":"39279","text":"26210"},"Replace `proc` with `(proc)`",{"range":"39280","text":"39281"},"Replace `·type:·'parent',·proc,·isExpanded:·expandedRows[proc.name]·||·false·})` with `⏎········type:·\"parent\",⏎········proc,⏎········isExpanded:·expandedRows[proc.name]·||·false,⏎······});`",{"range":"39282","text":"39283"},"Replace `child·=>·list.push({·type:·'child',·proc,·child·}))` with `(child)·=>⏎··········list.push({·type:·\"child\",·proc,·child·}),⏎········);`",{"range":"39284","text":"39285"},{"range":"39286","text":"26175"},{"range":"39287","text":"26175"},{"range":"39288","text":"26175"},"Replace `p·=>·p.children)` with `(p)·=>·p.children);`",{"range":"39289","text":"39290"},{"range":"39291","text":"26175"},"Replace `()·=>·startupApps.filter(s·=>·s.Name?.toLowerCase().includes(searchTerm.toLowerCase())),·[startupApps,·searchTerm])` with `⏎····()·=>⏎······startupApps.filter((s)·=>⏎········s.Name?.toLowerCase().includes(searchTerm.toLowerCase()),⏎······),⏎····[startupApps,·searchTerm],⏎··);`",{"range":"39292","text":"39293"},"Replace `()·=>·services.filter(s·=>·s.name?.toLowerCase().includes(searchTerm.toLowerCase())),·[services,·searchTerm])` with `⏎····()·=>⏎······services.filter((s)·=>⏎········s.name?.toLowerCase().includes(searchTerm.toLowerCase()),⏎······),⏎····[services,·searchTerm],⏎··);`",{"range":"39294","text":"39295"},["39296","39297"],{"range":"39298","text":"26175"},"Replace `·setActiveTab(id);·setSearchTerm('');` with `⏎··········setActiveTab(id);⏎··········setSearchTerm(\"\");⏎·······`",{"range":"39299","text":"39300"},"Replace `'bg-emerald-500/15'·:·'hover:bg-emerald-500/5'` with `\"bg-emerald-500/15\"·:·\"hover:bg-emerald-500/5\"`",{"range":"39301","text":"39302"},"Replace `·<div·className=\"absolute·left-0·top-0·bottom-0·w-1·bg-emerald-400·drop-shadow-[0_0_8px_rgba(16,185,129,0.8)]\"·/>` with `·(⏎··········<div·className=\"absolute·left-0·top-0·bottom-0·w-1·bg-emerald-400·drop-shadow-[0_0_8px_rgba(16,185,129,0.8)]\"·/>⏎········)`",{"range":"39303","text":"39304"},"Replace `·size={18}·className={`transition-colors·${isActive·?·'text-emerald-400'·:·'text-emerald-500/50'}`}` with `⏎··········size={18}⏎··········className={`transition-colors·${isActive·?·\"text-emerald-400\"·:·\"text-emerald-500/50\"}`}⏎·······`",{"range":"39305","text":"39306"},"Replace `·className={`text-[13px]·tracking-wide·transition-colors·${isActive·?·'text-emerald-300·font-bold'·:·'text-zinc-400·font-medium'}`}` with `⏎··········className={`text-[13px]·tracking-wide·transition-colors·${isActive·?·\"text-emerald-300·font-b