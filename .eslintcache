pure function. Calling an impure function can produce unstable results that update unpredictably when the component happens to re-render. (https://react.dev/reference/rules/components-and-hooks-must-be-pure#components-and-hooks-must-be-idempotent).\n\nE:\\Projects\\ui test\\jarvis-unified - Copy\\apps\\desktop\\renderer\\src\\components\\dashboard\\sphere.tsx:21:17\n  19 |\n  20 |     for (let i = 0; i < count; i++) {\n> 21 |       const x = Math.random() * 2 - 1\n     |                 ^^^^^^^^^^^^^ Cannot call impure function\n  22 |       const y = Math.random() * 2 - 1\n  23 |       const z = Math.random() * 2 - 1\n  24 |",{"range":"31147","text":"26175"},"Error: Cannot call impure function during render\n\n`Math.random` is an impure function. Calling an impure function can produce unstable results that update unpredictably when the component happens to re-render. (https://react.dev/reference/rules/components-and-hooks-must-be-pure#components-and-hooks-must-be-idempotent).\n\nE:\\Projects\\ui test\\jarvis-unified - Copy\\apps\\desktop\\renderer\\src\\components\\dashboard\\sphere.tsx:22:17\n  20 |     for (let i = 0; i < count; i++) {\n  21 |       const x = Math.random() * 2 - 1\n> 22 |       const y = Math.random() * 2 - 1\n     |                 ^^^^^^^^^^^^^ Cannot call impure function\n  23 |       const z = Math.random() * 2 - 1\n  24 |\n  25 |       const vector = new THREE.Vector3(x, y, z)",{"range":"31148","text":"26175"},"Error: Cannot call impure function during render\n\n`Math.random` is an impure function. Calling an impure function can produce unstable results that update unpredictably when the component happens to re-render. (https://react.dev/reference/rules/components-and-hooks-must-be-pure#components-and-hooks-must-be-idempotent).\n\nE:\\Projects\\ui test\\jarvis-unified - Copy\\apps\\desktop\\renderer\\src\\components\\dashboard\\sphere.tsx:23:17\n  21 |       const x = Math.random() * 2 - 1\n  22 |       const y = Math.random() * 2 - 1\n> 23 |       const z = Math.random() * 2 - 1\n     |                 ^^^^^^^^^^^^^ Cannot call impure function\n  24 |\n  25 |       const vector = new THREE.Vector3(x, y, z)\n  26 |       vector.normalize().multiplyScalar(2)",{"range":"31149","text":"26175"},{"range":"31150","text":"26210"},{"range":"31151","text":"26175"},{"range":"31152","text":"26175"},{"range":"31153","text":"26210"},{"range":"31154","text":"26175"},{"range":"31155","text":"26175"},{"range":"31156","text":"26175"},{"range":"31157","text":"26210"},{"range":"31158","text":"26175"},{"range":"31159","text":"26175"},{"range":"31160","text":"26175"},{"range":"31161","text":"26210"},"Error: Cannot call impure function during render\n\n`Math.random` is an impure function. Calling an impure function can produce unstable results that update unpredictably when the component happens to re-render. (https://react.dev/reference/rules/components-and-hooks-must-be-pure#components-and-hooks-must-be-idempotent).\n\nE:\\Projects\\ui test\\jarvis-unified - Copy\\apps\\desktop\\renderer\\src\\components\\dashboard\\sphere.tsx:36:19\n  34 |       orig[i * 3 + 2] = vector.z\n  35 |\n> 36 |       spread[i] = Math.random()\n     |                   ^^^^^^^^^^^^^ Cannot call impure function\n  37 |     }\n  38 |     return { positions: pos, originalPositions: orig, spreadFactors: spread }\n  39 |   }, [count])",{"range":"31162","text":"26175"},{"range":"31163","text":"26210"},{"range":"31164","text":"26175"},{"range":"31165","text":"26175"},{"range":"31166","text":"26210"},{"range":"31167","text":"26210"},{"range":"31168","text":"26175"},{"range":"31169","text":"26210"},["31170","31171"],{"range":"31172","text":"26210"},"Replace `(e.detail·===·'SPEAKING')␍` with `e.detail·===·\"SPEAKING\";`",{"range":"31173","text":"31174"},{"range":"31175","text":"26175"},{"range":"31176","text":"30664"},{"range":"31177","text":"30664"},{"range":"31178","text":"26175"},{"range":"31179","text":"26210"},{"range":"31180","text":"26175"},{"range