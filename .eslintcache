50"},{"range":"34579","text":"26210"},{"range":"34580","text":"26175"},{"range":"34581","text":"26175"},{"range":"34582","text":"26210"},{"range":"34583","text":"26175"},{"range":"34584","text":"26175"},{"range":"34585","text":"26210"},"Replace `'INITIALIZING·OPTICS...')␍` with `\"INITIALIZING·OPTICS...\");`",{"range":"34586","text":"34587"},{"range":"34588","text":"26175"},{"range":"34589","text":"26210"},{"range":"34590","text":"26175"},{"range":"34591","text":"26175"},{"range":"34592","text":"26210"},{"range":"34593","text":"26175"},{"range":"34594","text":"26175"},{"range":"34595","text":"26175"},{"range":"34596","text":"26175"},{"range":"34597","text":"26210"},{"range":"34598","text":"26175"},{"range":"34599","text":"26210"},{"range":"34600","text":"26210"},"Replace `()·=>·setTime(new·Date().toLocaleTimeString()),·1000)␍` with `⏎······()·=>·setTime(new·Date().toLocaleTimeString()),⏎······1000,⏎····);`",{"range":"34601","text":"34602"},{"range":"34603","text":"26175"},{"range":"34604","text":"26175"},{"range":"34605","text":"26210"},{"range":"34606","text":"26210"},{"range":"34607","text":"26210"},{"range":"34608","text":"26210"},"Replace `'check-vault-status')␍` with `\"check-vault-status\")`",{"range":"34609","text":"34610"},{"range":"34611","text":"26210"},{"range":"34612","text":"26175"},{"range":"34613","text":"26175"},{"range":"34614","text":"26175"},"Replace `'face')·loadNeuralNets(!status.hasFace)␍` with `\"face\")·loadNeuralNets(!status.hasFace);`",{"range":"34615","text":"34616"},"Error: Cannot access variable before it is declared\n\n`loadNeuralNets` is accessed before it is declared, which prevents the earlier access from updating when this value changes over time.\n\nE:\\Projects\\ui test\\jarvis-unified - Copy\\apps\\desktop\\renderer\\src\\layouts\\lock-screen.tsx:60:36\n  58 |           setNeedsFaceSetup(!status.hasFace)\n  59 |           setIsLoading(false)\n> 60 |           if (authMode === 'face') loadNeuralNets(!status.hasFace)\n     |                                    ^^^^^^^^^^^^^^ `loadNeuralNets` accessed before it is declared\n  61 |         })\n  62 |         .catch(() => setIsLoading(false))\n  63 |     } else {\n\nE:\\Projects\\ui test\\jarvis-unified - Copy\\apps\\desktop\\renderer\\src\\layouts\\lock-screen.tsx:108:3\n  106 |   }\n  107 |\n> 108 |   const loadNeuralNets = async (isFaceSetup: boolean) => {\n      |   ^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^\n> 109 |     try {\n      | ^^^^^^^^^\n> 110 |       setAiStatus('LOADING NEURAL NETS...')\n      …\n      | ^^^^^^^^^\n> 121 |     }\n      | ^^^^^^^^^\n> 122 |   }\n      | ^^^^ `loadNeuralNets` is declared here\n  123 |\n  124 |   const triggerAccessGranted = () => {\n  125 |     setIsAuthorized(true)",{"range":"34617","text":"26210"},{"range":"34618","text":"26175"},{"range":"34619","text":"26210"},"Error: Calling setState synchronously within an effect can trigger cascading renders\n\nEffects are intended to synchronize state between React and external systems such as manually updating the DOM, state management libraries, or other platform APIs. In general, the body of an effect should do one or both of the following:\n* Update external systems with the latest state from React.\n* Subscribe for updates from some external system, calling setState in a callback function when external state changes.\n\nCalling setState synchronously within an effect body causes cascading renders that can hurt performance, and is not recommended. (https://react.dev/learn/you-might-not-need-an-effect).\n\nE:\\Projects\\ui test\\jarvis-unified - Copy\\apps\\desktop\\renderer\\src\\layouts\\lock-screen.tsx:64:7\n  62 |         .catch(() => setIsLoading(false))\n  63 |     } else {\n> 64 |       setIsLoading(false)\n     |       ^^^^^^^^^^^^ Avoid calling setState() directly within an effect\n  65 |     }\n  66 |     return () => stopCamera()\n  67 |   }, [])",{"range":"34620","text":"26175"},{"range":"34621","text":"26210"},"Error: Cannot access variable before it is declared\n\n`stopCamera` is accessed before it is declared, which prevents the earlier access from updating when this value changes over time.\n\nE:\\Projects\\ui test\\jarvis-unified - Copy\\apps\\desktop\\renderer\\src\\layouts\\lock-screen.tsx:66:18\n  64 |       setIsLoading(false)\n  65 |     }\n> 66 |     return () => stopCamera()\n     |                  ^^^^^^^^^^ `stopCamera` accessed before it is declared\n  67 |   }, [])\n  68 |\n  69 |   useEffect(() => {\n\nE:\\Projects\\ui test\\jarvis-unified - Copy\\apps\\desktop\\renderer\\src\\layouts\\lock-screen.tsx:98:3\n   96 |   }\n   97 |\n>  98 |   const stopCamera = () => {\n      |   ^^^^^^^^^^^^^^^^^^^^^^^^^^\n>  99 |     if (scanIntervalRef.current) clearInterval(scanIntervalRef.current)\n      | ^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^\n> 100 |     if (videoRef.current && videoRef.current.srcObject) {\n      | ^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^\n> 101 |       const stream = videoRef.current.srcObject as MediaStream\n      | ^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^\n> 102 |       stream.getTracks().forEach((track) => track.stop())\n      | ^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^\n> 103 |       videoRef.current.srcObject = null\n      | ^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^\n> 104 |     }\n      | ^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^\n> 105 |     setIsScanning(false)\n      | ^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^\n> 106 |   }\n      | ^^^^ `stopCamera` is declared here\n  107 |\n  108 |   const loadNeuralNets = async (isFaceSetup: boolean) => {\n  109 |     try {",{"range":"34622","text":"26175"},"React Hook useEffect has missing dependencies: 'authMode' and 'loadNeuralNets'. Either include them or remove the dependency array.",["34623"],{"range":"346